# Required: Hugging Face model id
MODEL_ID="PekingU/rtdetr_r50vd"

# Required: Model revision (for reproducibility)
REVISION="main"

# Required for pipeline scripts: path to input video
VIDEO_PATH="./filter_example_video.mp4"

# Optional: Detection confidence threshold in [0, 1] (default: 0.3)
# THRESHOLD="0.3"

# Optional: Number of top classes for image-classification (default: 5)
# TOP_K="5"

# Optional: Enable visualization overlay (default: false)
# DRAW_VISUALIZATION="true"

# Optional: Webvis port (default: 8010)
# PORT="8010"

# Optional: Log level
# LOG_LEVEL="INFO"
