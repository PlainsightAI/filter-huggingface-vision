#!/usr/bin/env python3
import argparse
import shutil
from pathlib import Path
from subprocess import getoutput
from typing import Dict, List, Sequence, Union

THIS_FILE = Path(__file__).expanduser().absolute()
REPO_DIR = THIS_FILE.parent
DISABLED_WORKFLOWS_DIR = REPO_DIR / ".github" / "disabled-workflows"


def get_repo_name() -> str:
    return getoutput("basename $(git config remote.origin.url) .git").strip()


def get_repo_owner() -> str:
    return (
        getoutput("git config remote.origin.url")
        .strip()
        .replace("https://github.com/", "")
        .replace("git@github.com:", "")
        .split("/")[0]
    )


def recursive_get_files(
    root_dir: Union[Path, str], excepted_files: Sequence[Union[str, Path]] = ()
) -> List[Path]:
    if isinstance(root_dir, str):
        root_dir = Path(root_dir)
    return [x for x in root_dir.glob("**/*") if x not in excepted_files and x.is_file()]

def get_filter_name(name: str) -> str:
    words = name.replace("-", " ").replace("_", " ").split()
    if words[0] == "filter":
        words = words[1:]
    return " ".join(word.capitalize() for word in words)

PLACEHOLDERS = {
    "{{REPO_NAME}}": get_repo_name(),
    "{{REPO_NAME_SNAKECASE}}": REPO_DIR.name.replace("-", "_"),
    "{{REPO_NAME_KEBABCASE}}": REPO_DIR.name.replace("_", "-"),
    "{{REPO_NAME_PASCALCASE}}": ''.join(s.capitalize() for s in REPO_DIR.name.replace("-", "_").split('_')),
    "{{REPO_NAME_ALLCAPS}}": REPO_DIR.name.upper().replace("-", "_"),
    "{{REPO_OWNER}}": get_repo_owner(),
    "{{FILTER_NAME}}": get_filter_name(REPO_DIR.name),
}


def enable_workflow(path: Union[str, Path]):
    # Move from 'disabled-workflows' to 'workflows' directory.
    dest = Path(str(path).replace("disabled-workflows", "workflows"))
    dest.parent.mkdir(exist_ok=True)
    shutil.move(path, dest)


def substitute_placeholders(path: Union[str, Path], placeholder_map: Dict[str, str]):
    # Replace placeholders in file names
    for placeholder, value in placeholder_map.items():
        if placeholder in str(path):
            dest = Path(str(path).replace(placeholder, value))
            dest.parent.mkdir(exist_ok=True)
            path = shutil.move(path, dest)

    # Attempt to read *text* contents from file
    try:
        with open(path, "r") as f:
            content = f.read()
    except UnicodeDecodeError:
        # file is binary
        return

    # Replace placeholders in file contents
    for placeholder, value in placeholder_map.items():
        if placeholder in content:
            content = content.replace(placeholder, value)

    # Write modified contents back to file
    with open(path, "w") as f:
        f.write(content)

def modify_dockerfile(use_model: bool):
    "Comment the unnecessary model file caching parts of dockerfile for Filters that don't need Models at all"
    dockerfile = REPO_DIR / "Dockerfile"
    if not dockerfile.exists():
        return

    lines = dockerfile.read_text().splitlines()
    modified = []

    for line in lines:
        stripped = line.lstrip()
        # Always comment dev FROM line
        if "plainsightai-dev/oci" in stripped and "as model" in stripped:
            if not stripped.startswith("#"):
                line = "# " + line
            modified.append(line)
            continue

        # Conditionally uncomment prod FROM line
        if "plainsightai-prod/oci" in stripped and "as model" in stripped:
            if use_model and stripped.startswith("#"):
                line = line.replace("# ", "", 1)
            elif not use_model and not stripped.startswith("#"):
                line = "# " + line
            modified.append(line)
            continue

        # Conditionally uncomment/collapse model-related Dockerfile instructions
        model_related_keywords = [
            "--from=model",
            "chmod +x /app/entrypoint.sh",
            'ENTRYPOINT ["/app/entrypoint.sh"]',
            "ENV TRANSFORMERS_CACHE",
            "ENV HF_HOME",
        ]
        instruction_line = stripped[2:].lstrip() if stripped.startswith("# ") else stripped
        is_docker_instruction = instruction_line.startswith(("COPY", "ENV", "ENTRYPOINT", "RUN"))

        if any(keyword in stripped for keyword in model_related_keywords) and is_docker_instruction:
            if use_model and stripped.startswith("# "):
                line = line.replace("# ", "", 1)
            elif not use_model and not stripped.startswith("#"):
                line = "# " + line

        modified.append(line)

    dockerfile.write_text("\n".join(modified) + "\n")



def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--model", action="store_true", help="Comment out certain lines in Dockerfile based on if we need a Model in the Filter or not")
    args = parser.parse_args()

    for filename in recursive_get_files(DISABLED_WORKFLOWS_DIR):
        enable_workflow(filename)

    git_files = recursive_get_files(REPO_DIR / ".git")
    for filename in recursive_get_files(REPO_DIR, excepted_files=git_files):
        substitute_placeholders(filename, placeholder_map=PLACEHOLDERS)

    modify_dockerfile(args.model)
    DISABLED_WORKFLOWS_DIR.rmdir()
    Path("{{REPO_NAME_SNAKECASE}}").rmdir()
    THIS_FILE.unlink()


if __name__ == "__main__":
    main()
